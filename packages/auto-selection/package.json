{
    "name": "react-canvas-masker-auto-selection",
    "version": "1.0.0",
    "description": "Plugin for react-canvas-masker that automatically detects objects in an image and generates masks for them.",
    "keywords": [
        "react",
        "canvas",
        "mask",
        "image",
        "segmentation",
        "object-detection",
        "react-canvas-masker",
        "plugin"
    ],
    "license": "Apache-2.0",
    "author": "Vinicius Egidio <vegidio@gmail.com> (https://vinicius.io)",
    "repository": {
        "type": "git",
        "url": "https://github.com/vegidio/react-canvas-masker-auto-selection.git",
        "directory": "packages/auto-selection"
    },
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "LICENSE"
    ],
    "sideEffects": false,
    "scripts": {
        "build": "vite build",
        "dev": "vite build --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "typecheck": "tsc --noEmit",
        "clean": "rm -rf dist"
    },
    "peerDependencies": {
        "onnxruntime-web": "^1.24.3",
        "react": ">=18.0.0 <20.0.0",
        "react-canvas-masker": "^1.2.0",
        "react-dom": ">=18.0.0 <20.0.0"
    },
    "peerDependenciesMeta": {
        "onnxruntime-web": {
            "optional": true
        }
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "happy-dom": "^20.9.0",
        "onnxruntime-web": "^1.24.3",
        "react": "^19.2.5",
        "react-canvas-masker": "^1.2.0",
        "react-dom": "^19.2.5",
        "typescript": "^6.0.3",
        "vite": "^8.0.10",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^4.1.5"
    },
    "publishConfig": {
        "access": "public"
    }
}
